---
import BaseLayout from "../layouts/BaseLayout.astro";
import churchData from "../data/church.json";
---

<BaseLayout title="오시는 길">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title">오시는 길</h1>
      <p class="page-subtitle">여러분이 처음 오시는 길이 낯설 수 있어요. 아래 안내를 확인하고 편하게 오세요.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="address-card card">
        <h2 class="card-heading">주소</h2>
        <p class="address-text">{churchData.address}</p>
        <div class="contact-row">
          <span class="contact-label">전화</span>
          <a href={`tel:${churchData.phone.replace(/-/g, "")}`} class="phone-link">{churchData.phone}</a>
        </div>
        <p class="address-note">
          궁금한 점이 있으시면 전화 주세요. 편하게 안내해 드릴게요.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-alt" id="first-visit">
    <div class="container">
      <h2 class="section-title">처음 방문하시는 분께</h2>
      <p class="section-intro">
        낯선 곳에 처음 가는 건 누구나 조금 긴장되는 일이에요.
        그래서 미리 알아두시면 좋을 것들을 정리했어요.
      </p>

      <div class="info-grid">
        <div class="info-card card">
          <h3 class="info-heading">주차 안내</h3>
          <p>
            교회 건물 앞에 주차 공간이 있어요.
            자리가 부족할 때는 주변 공영주차장을 이용하실 수 있어요.
            오시는 길에 막히면 전화 주세요 — 안내해 드릴게요.
          </p>
        </div>

        <div class="info-card card">
          <h3 class="info-heading">복장</h3>
          <p>
            편하게 입고 오세요. 정말이에요.
            정장을 입으셔도 좋고, 캐주얼하게 오셔도 전혀 문제없어요.
            중요한 건 옷이 아니라 함께하는 마음이거든요.
          </p>
        </div>

        <div class="info-card card">
          <h3 class="info-heading">교회 분위기</h3>
          <p>
            소규모 교회라 따뜻한 분위기예요.
            처음 오신 분께 먼저 다가가 인사드리려고 해요.
            조용히 예배만 드리고 싶으시면 그것도 괜찮아요 — 부담 갖지 마세요.
          </p>
        </div>

        <div class="info-card card">
          <h3 class="info-heading">예배 시간</h3>
          <ul class="visit-service-list">
            {churchData.services.map((svc) => (
              <li>
                <strong>{svc.name}</strong> — {svc.time}
              </li>
            ))}
          </ul>
          <p class="visit-tip">
            처음이시라면 주일예배(오전 11시)에 오시는 걸 추천드려요.
            가장 많은 분들을 만나실 수 있거든요.
          </p>
        </div>
      </div>

      <div class="promise-box">
        <p>
          처음이라 어색하더라도 괜찮아요.
          저희가 먼저 다가갈게요.
          <strong>한 번 오시면, 다음에는 아는 얼굴이 있을 거예요.</strong>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background-color: var(--color-primary);
    color: var(--color-text-inverse);
    padding: var(--space-2xl) 0;
    text-align: center;
  }

  .page-title {
    font-size: var(--font-size-h1);
    color: var(--color-text-inverse);
    margin-bottom: var(--space-sm);
  }

  .page-subtitle {
    font-size: var(--font-size-h3);
    color: rgba(255, 255, 255, 0.85);
    max-width: 540px;
    margin: 0 auto;
  }

  .section {
    padding: var(--space-2xl) 0;
  }

  .section-alt {
    background-color: rgba(212, 168, 67, 0.04);
  }

  .section-title {
    font-size: var(--font-size-h2);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .section-intro {
    line-height: var(--line-height-base);
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    max-width: 580px;
  }

  .address-card {
    padding: var(--card-padding);
  }

  .card-heading {
    font-size: var(--font-size-h3);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .address-text {
    font-size: var(--font-size-h3);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .contact-label {
    font-weight: 600;
    color: var(--color-text-light);
  }

  .phone-link {
    font-weight: 600;
    color: var(--color-primary);
    font-size: var(--font-size-h3);
  }

  .address-note {
    color: var(--color-text-light);
    font-size: var(--font-size-sm);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .info-card {
    padding: var(--card-padding);
  }

  .info-heading {
    font-size: var(--font-size-h3);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .info-card p,
  .info-card li {
    line-height: var(--line-height-base);
    color: var(--color-text);
  }

  .visit-service-list {
    list-style: none;
    margin-bottom: var(--space-md);
  }

  .visit-service-list li {
    padding: var(--space-xs) 0;
  }

  .visit-tip {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-top: var(--space-sm);
  }

  .promise-box {
    border-left: 4px solid var(--color-accent);
    background-color: var(--color-bg-card);
    padding: var(--space-lg) var(--space-xl);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
  }

  .promise-box p {
    line-height: var(--line-height-base);
    font-size: var(--font-size-base);
  }
</style>
